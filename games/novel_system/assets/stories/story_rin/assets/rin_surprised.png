<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1200" width="800" height="1200">
    <g transform="translate(400, 350)">
      <!-- Long Dark Blue Hair -->
      <path d="M-240,-100 C-280,180 -220,500 -160,750 C-100,600 100,600 160,750 C220,500 280,180 240,-100 Z" fill="#1e1b4b"/>
      <!-- Body / Student Council Suit -->
      <g transform="translate(0, 220)">
        <path d="M-160,100 C-140,0 -80,-40 0,-40 C80,-40 140,0 160,100 L180,450 L-180,450 Z" fill="#0f172a"/>
        <!-- Red Tie & White Shirt -->
        <polygon points="-40,-40 0,60 40,-40" fill="#ffffff"/>
        <polygon points="-12,-20 0,160 12,-20" fill="#dc2626"/>
        <!-- Armband -->
        <rect x="-170" y="80" width="40" height="70" fill="#ef4444"/>
        <text x="-150" y="125" font-family="'Noto Sans TC', sans-serif" font-weight="700" font-size="18" fill="#ffffff" text-anchor="middle" writing-mode="tb">會長</text>
      </g>
      <!-- Head Base -->
      <path d="M-110,0 C-110,130 110,130 110,0 C110,-100 -110,-100 -110,0 Z" fill="#ffe0bd"/>
      <!-- Straight Bangs -->
      <path d="M-130,-50 C-140,-160 -60,-170 0,-170 C60,-170 140,-160 130,-50 L90,-30 L40,-70 L0,-30 L-40,-70 L-90,-30 Z" fill="#312e81"/>
      <!-- Red Glasses -->
      <g stroke="#dc2626" stroke-width="4" fill="none">
        <rect x="-70" y="-10" width="55" height="35" rx="6"/>
        <rect x="15" y="-10" width="55" height="35" rx="6"/>
        <line x1="-15" y1="5" x2="15" y2="5"/>
      </g>
      <!-- Face Features -->
      <g transform="translate(0, -10)">
        <path d="M-55,-20 Q-35,-35 -15,-20" fill="none" stroke="#1e1b4b" stroke-width="6"/>
                <path d="M15,-20 Q35,-35 55,-20" fill="none" stroke="#1e1b4b" stroke-width="6"/>
        <ellipse cx="-35" cy="15" rx="14" ry="20" fill="#312e81"/>
              <ellipse cx="35" cy="15" rx="14" ry="20" fill="#312e81"/>
              <circle cx="-30" cy="10" r="5" fill="#ffffff"/>
              <circle cx="40" cy="10" r="5" fill="#ffffff"/>
        
        <ellipse cx="0" cy="65" rx="12" ry="18" fill="#312e81"/>
      </g>
    </g>
  </svg>