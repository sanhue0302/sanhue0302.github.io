<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1500" width="1000" height="1500">
  <defs>
    <linearGradient id="rinBg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0f172a"/>
      <stop offset="50%" stop-color="#1e1b4b"/>
      <stop offset="100%" stop-color="#312e81"/>
    </linearGradient>
    <linearGradient id="moonGlow" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#e0e7ff"/>
      <stop offset="100%" stop-color="#818cf8"/>
    </linearGradient>
  </defs>
  <rect width="1000" height="1500" fill="url(#rinBg)"/>
  <!-- Crescent Moon -->
  <path d="M750,200 A160,160 0 1,0 850,450 A200,200 0 1,1 750,200 Z" fill="url(#moonGlow)"/>
  <!-- Stars -->
  <circle cx="200" cy="150" r="4" fill="#ffffff" opacity="0.9"/>
  <circle cx="450" cy="300" r="3" fill="#ffffff" opacity="0.7"/>
  <circle cx="150" cy="600" r="5" fill="#a5b4fc" opacity="0.8"/>
  <circle cx="850" cy="700" r="4" fill="#ffffff" opacity="0.9"/>
  <!-- Rin Silhouette / Character -->
  <g transform="translate(500, 720)">
    <!-- Long Hair -->
    <path d="M-160,-160 C-220,0 -200,200 -160,350 C-100,200 -60,0 -30,-160 C0,-180 40,-180 80,-160 C110,0 150,200 210,350 C250,200 270,0 210,-160 C150,-280 -100,-280 -160,-160 Z" fill="#1e293b"/>
    <!-- Head -->
    <ellipse cx="25" cy="-50" rx="95" ry="115" fill="#ffe0bd"/>
    <!-- Eyes Tsundere -->
    <path d="M-40,-60 L10,-45" stroke="#312e81" stroke-width="8" stroke-linecap="round"/>
    <path d="M40,-45 L90,-60" stroke="#312e81" stroke-width="8" stroke-linecap="round"/>
    <ellipse cx="-15" cy="-45" rx="16" ry="22" fill="#4338ca"/>
    <ellipse cx="65" cy="-45" rx="16" ry="22" fill="#4338ca"/>
    <!-- Smirk -->
    <path d="M10,20 Q30,10 45,25" fill="none" stroke="#4338ca" stroke-width="5" stroke-linecap="round"/>
    <!-- Red Glasses Rim -->
    <rect x="-40" y="-65" width="50" height="35" rx="6" fill="none" stroke="#ef4444" stroke-width="4"/>
    <rect x="40" y="-65" width="50" height="35" rx="6" fill="none" stroke="#ef4444" stroke-width="4"/>
    <line x1="10" y1="-50" x2="40" y2="-50" stroke="#ef4444" stroke-width="4"/>
  </g>
  <!-- Card info -->
  <rect x="80" y="1120" width="840" height="280" rx="24" fill="rgba(15, 23, 42, 0.85)" stroke="#6366f1" stroke-width="3"/>
  <text x="500" y="1210" font-family="'Noto Sans TC', sans-serif" font-weight="900" font-size="52" fill="#a5b4fc" text-anchor="middle">月夜下的約定</text>
  <text x="500" y="1270" font-family="'Noto Sans TC', sans-serif" font-weight="500" font-size="28" fill="#cbd5e1" text-anchor="middle">高冷學生會長凜的秘密特訓與隱藏心意...</text>
  <rect x="420" y="1310" width="160" height="42" rx="21" fill="#4f46e5"/>
  <text x="500" y="1339" font-family="'Noto Sans TC', sans-serif" font-weight="700" font-size="20" fill="#ffffff" text-anchor="middle">3 個結局</text>
</svg>