<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1200" width="800" height="1200">
    <g transform="translate(400, 350)">
      <!-- Back Hair -->
      <path d="M-220,-80 C-260,150 -200,450 -140,650 C-100,550 100,550 140,650 C200,450 260,150 220,-80 Z" fill="#ff6699"/>
      <!-- Body / School Uniform -->
      <g transform="translate(0, 220)">
        <path d="M-160,100 C-140,0 -80,-40 0,-40 C80,-40 140,0 160,100 L180,450 L-180,450 Z" fill="#3f51b5"/>
        <!-- Sailor Collar -->
        <path d="M-120,-30 L0,120 L120,-30 L160,-20 L0,160 L-160,-20 Z" fill="#ffffff"/>
        <!-- Red Ribbon Tie -->
        <polygon points="0,60 -30,140 0,120 30,140" fill="#e91e63"/>
        <circle cx="0" cy="60" r="12" fill="#c2185b"/>
      </g>
      <!-- Head Base -->
      <path d="M-110,0 C-110,130 110,130 110,0 C110,-100 -110,-100 -110,0 Z" fill="#ffe4d6"/>
      <!-- Bangs Hair -->
      <path d="M-130,-50 C-140,-150 -60,-170 0,-170 C60,-170 140,-150 130,-50 C90,-90 60,-30 30,-80 C0,-20 -30,-80 -60,-30 C-90,-90 -110,-70 -130,-50 Z" fill="#ff4d88"/>
      <!-- Hair Ribbon Pin -->
      <circle cx="-90" cy="-110" r="18" fill="#ffffff"/>
      <circle cx="-90" cy="-110" r="10" fill="#ff80ab"/>
      <!-- Face Features -->
      <g transform="translate(0, -10)">
        
        <path d="M-50,15 Q-35,-5 -20,15" fill="none" stroke="#3a1e28" stroke-width="6" stroke-linecap="round"/>
            <path d="M20,15 Q35,-5 50,15" fill="none" stroke="#3a1e28" stroke-width="6" stroke-linecap="round"/>
        <ellipse cx="-55" cy="40" rx="20" ry="10" fill="rgba(255,77,136,0.35)"/>
             <ellipse cx="55" cy="40" rx="20" ry="10" fill="rgba(255,77,136,0.35)"/>
        <path d="M-20,60 Q0,95 20,60 Z" fill="#ff4d88" stroke="#d6336c" stroke-width="3"/>
      </g>
    </g>
  </svg>