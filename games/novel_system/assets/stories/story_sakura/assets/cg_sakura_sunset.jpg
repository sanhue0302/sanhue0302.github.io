<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <linearGradient id="sunsetSky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#4a154b"/>
      <stop offset="35%" stop-color="#b13359"/>
      <stop offset="70%" stop-color="#f76c5e"/>
      <stop offset="100%" stop-color="#ffb86c"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#sunsetSky)"/>
  <!-- Sun -->
  <circle cx="960" cy="650" r="160" fill="#fffae6" opacity="0.9"/>
  <circle cx="960" cy="650" r="280" fill="rgba(255, 200, 100, 0.3)"/>
  <!-- Mountains Horizon -->
  <path d="M0,720 Q480,620 960,700 T1920,680 L1920,1080 L0,1080 Z" fill="#2d132c" opacity="0.9"/>
  <!-- Park Grass & Path -->
  <path d="M0,820 L1920,820 L1920,1080 L0,1080 Z" fill="#1f0923"/>
  <path d="M700,1080 L900,820 L1020,820 L1220,1080 Z" fill="#3d1e3d"/>
  <!-- Park Bench Silhouette -->
  <rect x="420" y="800" width="220" height="12" fill="#ea9085"/>
  <rect x="440" y="812" width="15" height="40" fill="#ea9085"/>
  <rect x="605" y="812" width="15" height="40" fill="#ea9085"/>
  <!-- Sakura Tree Silhouette at sunset -->
  <path d="M1400,900 C1400,750 1480,650 1520,500" stroke="#1f0923" stroke-width="40" stroke-linecap="round"/>
  <circle cx="1550" cy="450" r="220" fill="#872341" opacity="0.85"/>
  <circle cx="1400" cy="480" r="180" fill="#be3144" opacity="0.85"/>
</svg>
  <!-- Special Romantic Glowing Petals -->
  <g opacity="0.8">
    <circle cx="960" cy="500" r="8" fill="#ffffff"/>
    <circle cx="700" cy="400" r="12" fill="#ffb3c6"/>
    <circle cx="1200" cy="450" r="10" fill="#ffccd5"/>
    <circle cx="850" cy="650" r="14" fill="#ffffff"/>
  </g>
  <!-- Sakura Character Close-up -->
  <g transform="translate(960, 600)">
    <!-- Hair back -->
    <ellipse cx="0" cy="0" rx="320" ry="380" fill="#ff4d88"/>
    <!-- Head -->
    <ellipse cx="0" cy="0" rx="200" ry="240" fill="#ffe0bd"/>
    <!-- Blushing Face -->
    <ellipse cx="-100" cy="50" rx="50" ry="25" fill="rgba(255,50,120,0.6)"/>
    <ellipse cx="100" cy="50" rx="50" ry="25" fill="rgba(255,50,120,0.6)"/>
    <!-- Loving Eyes -->
    <ellipse cx="-70" cy="-20" rx="25" ry="38" fill="#3a1e28"/>
    <ellipse cx="70" cy="-20" rx="25" ry="38" fill="#3a1e28"/>
    <circle cx="-60" cy="-30" r="12" fill="#ffffff"/>
    <circle cx="80" cy="-30" r="12" fill="#ffffff"/>
    <circle cx="-75" cy="0" r="6" fill="#ff80ab"/>
    <circle cx="65" cy="0" r="6" fill="#ff80ab"/>
    <!-- Happy Tears / Emotion -->
    <path d="M-80,10 Q-85,40 -80,60" fill="none" stroke="#80d8ff" stroke-width="4"/>
    <path d="M80,10 Q85,40 80,60" fill="none" stroke="#80d8ff" stroke-width="4"/>
    <!-- Gentle Smile -->
    <path d="M-30,100 Q0,140 30,100" fill="none" stroke="#d6336c" stroke-width="8" stroke-linecap="round"/>
  </g>
  <!-- Gold Title Overlay Badge -->
  <rect x="1350" y="80" width="480" height="120" rx="16" fill="rgba(0, 0, 0, 0.6)" stroke="#ffd700" stroke-width="3"/>
  <text x="1590" y="135" font-family="'Klee One', serif" font-weight="700" font-size="34" fill="#ffd700" text-anchor="middle">★ CG 解鎖：櫻花下的告白</text>
  <text x="1590" y="175" font-family="'Noto Sans TC', sans-serif" font-weight="500" font-size="20" fill="#ffffff" text-anchor="middle">「其實...我一直都很喜歡你！」</text>
</svg>