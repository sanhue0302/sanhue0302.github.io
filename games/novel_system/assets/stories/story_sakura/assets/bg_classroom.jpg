<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <linearGradient id="wallGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#fff3e0"/>
      <stop offset="70%" stop-color="#ffe0b2"/>
      <stop offset="100%" stop-color="#d7ccc8"/>
    </linearGradient>
    <linearGradient id="windowSun" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#ffe082"/>
      <stop offset="100%" stop-color="#ffb74d"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#wallGrad)"/>
  <!-- Blackboard -->
  <rect x="300" y="150" width="1320" height="480" fill="#2e7d32" stroke="#5d4037" stroke-width="16" rx="8"/>
  <text x="960" y="320" font-family="'Klee One', serif" font-size="42" fill="#e8f5e9" text-anchor="middle">目標：開懷大笑的青春！</text>
  <line x1="400" y1="400" x2="1520" y2="400" stroke="#81c784" stroke-width="2" stroke-dasharray="10 10"/>
  <!-- Windows on the Left -->
  <rect x="40" y="100" width="200" height="600" fill="url(#windowSun)" stroke="#8d6e63" stroke-width="12"/>
  <line x1="40" y1="300" x2="240" y2="300" stroke="#8d6e63" stroke-width="8"/>
  <line x1="40" y1="500" x2="240" y2="500" stroke="#8d6e63" stroke-width="8"/>
  <line x1="140" y1="100" x2="140" y2="700" stroke="#8d6e63" stroke-width="8"/>
  <!-- Floor -->
  <path d="M0,750 L1920,750 L1920,1080 L0,1080 Z" fill="#a1887f"/>
  <line x1="0" y1="850" x2="1920" y2="850" stroke="#8d6e63" stroke-width="4"/>
  <line x1="0" y1="960" x2="1920" y2="960" stroke="#8d6e63" stroke-width="4"/>
  <!-- Desks Silhouettes -->
  <rect x="500" y="700" width="300" height="140" fill="#6d4c41" rx="6"/>
  <rect x="1100" y="700" width="300" height="140" fill="#6d4c41" rx="6"/>
</svg>