<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <linearGradient id="libBg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#2d1b0e"/>
      <stop offset="100%" stop-color="#4a2e1b"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#libBg)"/>
  <!-- Bookshelves -->
  <g fill="#3e2723" stroke="#1b0000" stroke-width="6">
    <rect x="100" y="100" width="450" height="750"/>
    <rect x="1370" y="100" width="450" height="750"/>
  </g>
  <!-- Books -->
  <g fill="#8d6e63">
    <rect x="120" y="140" width="30" height="120" fill="#c62828"/>
    <rect x="155" y="120" width="40" height="140" fill="#1565c0"/>
    <rect x="200" y="150" width="25" height="110" fill="#2e7d32"/>
    <rect x="230" y="130" width="35" height="130" fill="#f9a825"/>
    <rect x="1390" y="140" width="35" height="120" fill="#6a1b9a"/>
    <rect x="1430" y="120" width="40" height="140" fill="#00838f"/>
  </g>
  <!-- Stained Glass Window Center -->
  <polygon points="960,100 700,400 1220,400" fill="#ffe082" opacity="0.6"/>
  <circle cx="960" cy="300" r="120" fill="#4fc3f7" opacity="0.5"/>
  <!-- Wooden Floor -->
  <rect x="0" y="850" width="1920" height="230" fill="#24140e"/>
  <!-- Study Desk & Lamp -->
  <rect x="650" y="700" width="620" height="180" fill="#4e342e" rx="10"/>
  <path d="M720,700 L740,620 L800,620 L780,700 Z" fill="#ffd54f"/>
  <circle cx="760" cy="610" r="30" fill="#fff59d" opacity="0.9"/>
</svg>