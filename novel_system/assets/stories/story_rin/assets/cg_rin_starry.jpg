<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <linearGradient id="nightSky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#020617"/>
      <stop offset="50%" stop-color="#0f172a"/>
      <stop offset="100%" stop-color="#1e1b4b"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#nightSky)"/>
  <!-- Moon -->
  <circle cx="1500" cy="220" r="100" fill="#f8fafc"/>
  <circle cx="1500" cy="220" r="180" fill="rgba(248, 250, 252, 0.15)"/>
  <!-- Distant City Lights -->
  <g fill="#fef08a" opacity="0.7">
    <rect x="200" y="600" width="40" height="150"/>
    <rect x="280" y="550" width="60" height="200"/>
    <rect x="500" y="580" width="50" height="170"/>
    <rect x="1100" y="560" width="80" height="190"/>
    <rect x="1250" y="620" width="45" height="130"/>
  </g>
  <!-- Balcony Fence -->
  <rect x="0" y="750" width="1920" height="40" fill="#334155"/>
  <g fill="#475569">
    <rect x="100" y="790" width="20" height="290"/>
    <rect x="300" y="790" width="20" height="290"/>
    <rect x="500" y="790" width="20" height="290"/>
    <rect x="700" y="790" width="20" height="290"/>
    <rect x="900" y="790" width="20" height="290"/>
    <rect x="1100" y="790" width="20" height="290"/>
    <rect x="1300" y="790" width="20" height="290"/>
    <rect x="1500" y="790" width="20" height="290"/>
    <rect x="1700" y="790" width="20" height="290"/>
  </g>
  <rect x="0" y="880" width="1920" height="200" fill="#0f172a" opacity="0.95"/>
</svg>
  <!-- Stargazing Glow Particles -->
  <g opacity="0.9">
    <circle cx="400" cy="200" r="10" fill="#818cf8"/>
    <circle cx="800" cy="150" r="14" fill="#e0e7ff"/>
    <circle cx="1200" cy="300" r="8" fill="#ffffff"/>
  </g>
  <!-- Rin Character Loving Close-up -->
  <g transform="translate(960, 580)">
    <!-- Hair -->
    <ellipse cx="0" cy="0" rx="300" ry="360" fill="#1e1b4b"/>
    <!-- Head -->
    <ellipse cx="0" cy="0" rx="190" ry="230" fill="#ffe0bd"/>
    <!-- Soft Shy Blush -->
    <ellipse cx="-90" cy="45" rx="45" ry="22" fill="rgba(217,70,239,0.5)"/>
    <ellipse cx="90" cy="45" rx="45" ry="22" fill="rgba(217,70,239,0.5)"/>
    <!-- Glasses off or lowered -->
    <!-- Sweet Stargazing Eyes -->
    <ellipse cx="-65" cy="-20" rx="22" ry="34" fill="#312e81"/>
    <ellipse cx="65" cy="-20" rx="22" ry="34" fill="#312e81"/>
    <circle cx="-55" cy="-30" r="10" fill="#ffffff"/>
    <circle cx="75" cy="-30" r="10" fill="#ffffff"/>
    <!-- Tsundere Tender Smile -->
    <path d="M-25,95 Q0,125 25,95" fill="none" stroke="#4338ca" stroke-width="7" stroke-linecap="round"/>
  </g>
  <!-- Gold Title Overlay Badge -->
  <rect x="1350" y="80" width="480" height="120" rx="16" fill="rgba(15, 23, 42, 0.85)" stroke="#818cf8" stroke-width="3"/>
  <text x="1590" y="135" font-family="'Klee One', serif" font-weight="700" font-size="34" fill="#818cf8" text-anchor="middle">★ CG 解鎖：星空下的解心</text>
  <text x="1590" y="175" font-family="'Noto Sans TC', sans-serif" font-weight="500" font-size="20" fill="#ffffff" text-anchor="middle">「只有在你面前...我才不想逞強。」</text>
</svg>