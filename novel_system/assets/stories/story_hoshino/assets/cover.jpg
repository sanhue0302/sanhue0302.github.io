<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#2e1065"/>
      <stop offset="50%" stop-color="#701a75"/>
      <stop offset="100%" stop-color="#09090b"/>
    </linearGradient>
  </defs>
  <rect width="800" height="450" fill="url(#g1)"/>
  <circle cx="400" cy="180" r="120" fill="none" stroke="#f472b6" stroke-width="4" stroke-dasharray="10 6" opacity="0.6"/>
  <text x="400" y="210" fill="#f43f5e" font-size="70" text-anchor="middle" font-family="sans-serif" font-weight="900" opacity="0.3">✨ IDOL ✨</text>
  <text x="400" y="220" fill="#ffffff" font-size="42" text-anchor="middle" font-family="sans-serif" font-weight="bold">星野同級生</text>
  <text x="400" y="270" fill="#f472b6" font-size="22" text-anchor="middle" font-family="sans-serif">～ 她的全部都屬於我 ～</text>
</svg>