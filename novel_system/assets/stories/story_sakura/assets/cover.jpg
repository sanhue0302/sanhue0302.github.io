<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1500" width="1000" height="1500">
  <defs>
    <linearGradient id="bgGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#ffe6fa"/>
      <stop offset="50%" stop-color="#ffb3d9"/>
      <stop offset="100%" stop-color="#ff66a3"/>
    </linearGradient>
    <linearGradient id="glowGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgba(255,255,255,0.8)"/>
      <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
    </linearGradient>
    <filter id="shadow">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="1000" height="1500" fill="url(#bgGrad)"/>
  <!-- Cherry Blossom Petals -->
  <g opacity="0.6">
    <ellipse cx="200" cy="300" rx="40" ry="20" fill="#ffffff" transform="rotate(-30 200 300)"/>
    <ellipse cx="800" cy="500" rx="50" ry="25" fill="#ffffff" transform="rotate(25 800 500)"/>
    <ellipse cx="350" cy="800" rx="35" ry="18" fill="#ffffff" transform="rotate(-15 350 800)"/>
    <ellipse cx="700" cy="1100" rx="45" ry="22" fill="#ffffff" transform="rotate(40 700 1100)"/>
    <ellipse cx="150" cy="1300" rx="60" ry="28" fill="#ffffff" transform="rotate(-45 150 1300)"/>
  </g>
  <!-- Character Silhouette / Portrait Frame -->
  <circle cx="500" cy="650" r="320" fill="url(#glowGrad)"/>
  <!-- Sakura Character Graphic Silhouette / Face -->
  <g transform="translate(500, 680)">
    <!-- Hair -->
    <path d="M-140,-120 C-180,-40 -160,100 -120,180 C-80,100 -60,0 -40,-120 C0,-140 40,-140 80,-120 C100,0 120,100 160,180 C200,100 220,-40 180,-120 C120,-240 -120,-240 -140,-120 Z" fill="#ff4d88"/>
    <!-- Head -->
    <ellipse cx="20" cy="-30" rx="90" ry="110" fill="#ffe0bd"/>
    <!-- Eyes -->
    <ellipse cx="-20" cy="-30" rx="16" ry="24" fill="#3a1e28"/>
    <ellipse cx="60" cy="-30" rx="16" ry="24" fill="#3a1e28"/>
    <ellipse cx="-18" cy="-35" rx="6" ry="9" fill="#ffffff"/>
    <ellipse cx="62" cy="-35" rx="6" ry="9" fill="#ffffff"/>
    <!-- Smile -->
    <path d="M0,25 Q20,45 40,25" fill="none" stroke="#ff4d88" stroke-width="5" stroke-linecap="round"/>
    <!-- Ribbon -->
    <polygon points="20,-140 -20,-180 60,-180" fill="#ffffff"/>
    <polygon points="20,-140 60,-180 100,-180" fill="#ffffff"/>
    <circle cx="20" cy="-140" r="14" fill="#ffb3c6"/>
  </g>
  <!-- Decorative Overlay Card -->
  <rect x="80" y="1120" width="840" height="280" rx="24" fill="rgba(255, 255, 255, 0.85)" filter="url(#shadow)"/>
  <text x="500" y="1210" font-family="'Noto Sans TC', sans-serif" font-weight="900" font-size="52" fill="#d6336c" text-anchor="middle">櫻花下的再會</text>
  <text x="500" y="1270" font-family="'Noto Sans TC', sans-serif" font-weight="500" font-size="28" fill="#666666" text-anchor="middle">重溫春日初戀的約定與未解的心意...</text>
  <rect x="420" y="1310" width="160" height="42" rx="21" fill="#ff4d88"/>
  <text x="500" y="1339" font-family="'Noto Sans TC', sans-serif" font-weight="700" font-size="20" fill="#ffffff" text-anchor="middle">3 個結局</text>
</svg>