<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <linearGradient id="sunsetSky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#4a154b"/>
      <stop offset="35%" stop-color="#b13359"/>
      <stop offset="70%" stop-color="#f76c5e"/>
      <stop offset="100%" stop-color="#ffb86c"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#sunsetSky)"/>
  <!-- Sun -->
  <circle cx="960" cy="650" r="160" fill="#fffae6" opacity="0.9"/>
  <circle cx="960" cy="650" r="280" fill="rgba(255, 200, 100, 0.3)"/>
  <!-- Mountains Horizon -->
  <path d="M0,720 Q480,620 960,700 T1920,680 L1920,1080 L0,1080 Z" fill="#2d132c" opacity="0.9"/>
  <!-- Park Grass & Path -->
  <path d="M0,820 L1920,820 L1920,1080 L0,1080 Z" fill="#1f0923"/>
  <path d="M700,1080 L900,820 L1020,820 L1220,1080 Z" fill="#3d1e3d"/>
  <!-- Park Bench Silhouette -->
  <rect x="420" y="800" width="220" height="12" fill="#ea9085"/>
  <rect x="440" y="812" width="15" height="40" fill="#ea9085"/>
  <rect x="605" y="812" width="15" height="40" fill="#ea9085"/>
  <!-- Sakura Tree Silhouette at sunset -->
  <path d="M1400,900 C1400,750 1480,650 1520,500" stroke="#1f0923" stroke-width="40" stroke-linecap="round"/>
  <circle cx="1550" cy="450" r="220" fill="#872341" opacity="0.85"/>
  <circle cx="1400" cy="480" r="180" fill="#be3144" opacity="0.85"/>
</svg>